{
  "branding": {
    "name": "BTX Aerospace & Defense Monitor",
    "accent_color": "#38BDF8"
  },
  "editions": [
    {
      "id": "bd",
      "label": "Business Development",
      "audience_description": "BTX's BD and capture team tracking programs, funding, and prime-contractor activity BTX could win build-to-print and precision-machining work on",
      "analysis_instructions": "BTX is a build-to-print precision-machining (5-axis CNC, AS9100/ITAR) supplier to defense primes. Prioritise contract awards, solicitations, and RFPs to BTX's primes (Lockheed Martin, RTX, Northrop Grumman) and on its programs (F-35, B-21) — especially where the work implies machined flight-critical hardware BTX could subcontract for. Flag dollar values, performance periods, sole-source justifications, set-aside status, and protest activity. Treat a prime's new award as a subcontracting opening and say which BTX capability it maps to.",
      "categories": [
        "Contract Award",
        "Solicitation / RFP",
        "Subcontracting Opportunity",
        "Budget & Appropriations",
        "Industry News"
      ]
    },
    {
      "id": "exec",
      "label": "Executive Brief",
      "audience_description": "BTX leadership seeking the strategic, supply-chain, and ITAR/export-control developments that affect the business",
      "analysis_instructions": "Surface only the highest-signal items for BTX leadership: major program decisions on F-35/B-21, significant defense funding changes, supply-chain and raw-material developments that affect BTX's ability to deliver, and ITAR/EAR/DFARS or export-control actions that change BTX's compliance exposure. Tie each to BTX's goal of growing defense revenue or to its named risks. Skip routine administrative notices.",
      "categories": [
        "Program Decision",
        "Supply Chain",
        "Export Controls / Compliance",
        "Budget & Appropriations",
        "Industry News"
      ]
    }
  ],
  "scoring_rubric": {
    "thresholds": {
      "tier_1_min": 80,
      "tier_2_min": 50,
      "tier_3_min": 20
    },
    "never_discard": [
      "stop-work order",
      "stop work",
      "termination for default",
      "debarment",
      "suspension",
      "fraud",
      "bribery",
      "FCPA",
      "whistleblower",
      "False Claims Act",
      "program cancellation",
      "continuing resolution"
    ]
  },
