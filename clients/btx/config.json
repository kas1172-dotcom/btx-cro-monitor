  "deep_analysis": {
    "instruction": "Produce a concise but substantive briefing for BTX — a build-to-print precision-machining (5-axis CNC, AS9100/ITAR) supplier to defense primes such as Lockheed Martin, RTX, and Northrop Grumman, working programs like F-35 and B-21. Frame everything around what the development means for BTX's ability to win build-to-print / machined-hardware subcontract work, its prime relationships, and its supply-chain and ITAR/export-control exposure. Stay grounded in the item; flag uncertainty rather than speculating.",
    "sections": [
      {
        "id": "background",
        "label": "Background",
        "kind": "text",
        "instruction": "Two to three sentences situating this development: the program, contract, or policy thread it belongs to and what preceded it."
      },
      {
        "id": "key_stakeholders",
        "label": "Key stakeholders",
        "kind": "list",
        "instruction": "The agencies, primes, subcontractors, congressional actors, or allied governments with a material interest. Name them only if supported by the item."
      },
      {
        "id": "scenarios",
        "label": "Scenarios to watch",
        "kind": "list",
        "instruction": "Two or three plausible ways this could develop over the next 6–18 months, each phrased as a short conditional."
      },
      {
        "id": "recommended_actions",
        "label": "Recommended actions for BTX",
        "kind": "list",
        "instruction": "Concrete next steps for BTX's BD/capture and leadership this week — e.g. which prime to approach, which build-to-print/machining capability to position, or which compliance/supply-chain risk to mitigate. Tie each action to a specific BTX capability, customer, or risk."
      }
    ],
    "deep_batch_size": 6,
    "agentic": true,
    "agentic_tiers": [1],
    "max_research_steps": 4,
    "allow_fetch": true
  },
  "enrichers": [
    {
      "id": "usaspending-awards",
      "label": "Prime award activity (USAspending)",
      "applies_to_entity_types": ["organization"],
      "max_entities_per_run": 6,
      "connector": {
        "url": "https://api.usaspending.gov/api/v2/search/spending_by_award/",
        "method": "POST",
        "request_body": {
          "filters": {
            "recipient_search_text": ["{query}"],
            "award_type_codes": ["A", "B", "C", "D"],
            "time_period": [{ "start_date": "2023-10-01", "end_date": "2025-09-30" }]
          },
          "fields": ["Award ID", "Recipient Name", "Award Amount", "Awarding Agency", "Award Type"],
          "limit": 3,
          "sort": "Award Amount",
          "order": "desc"
        },
        "item_path": "$.results",
        "fact_map": [
          { "label": "Top recent award", "field": "Award Amount", "kind": "money" },
          { "label": "Awarding agency", "field": "Awarding Agency", "kind": "text" },
          { "label": "Award type", "field": "Award Type", "kind": "text" }
        ],
        "max_facts": 3
      }
    },
    {
      "id": "federal-register-program",
      "label": "Rulemaking & notices (Federal Register)",
      "applies_to_entity_types": ["program"],
      "max_entities_per_run": 6,
      "connector": {
        "url": "https://www.federalregister.gov/api/v1/documents.json?per_page=1&order=newest&fields[]=title&fields[]=html_url&fields[]=publication_date&conditions[term]={query}",
        "method": "GET",
        "item_path": "$.results",
        "url_field": "html_url",
        "fact_map": [
          { "label": "Latest Federal Register doc", "field": "title", "kind": "text" },
          { "label": "Published", "field": "publication_date", "kind": "date" }
        ],
        "max_facts": 2
      }
    }
  ],
