# Use artifact for the default public cockpit, or hybrid when the default should
# combine HubSpot CRM, monitor artifacts, and demo fallback data.
VITE_DATA_MODE=artifact
VITE_BACKEND_ENDPOINT=https://btx-platform.fly.dev
VITE_COPILOT_ENDPOINT=https://btx-platform.fly.dev/llm
VITE_ARTIFACT_BASE_URL=../btx

# Set these through GitHub Actions secrets for production builds.
# VITE_BACKEND_AUTH_TOKEN=
# VITE_COCKPIT_PASSWORD_HASH=
