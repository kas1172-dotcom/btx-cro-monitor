VITE_DATA_MODE=demo
# Valid modes: demo, artifact, live, hybrid.
# Point both backend-backed settings and Chatpil/LLM calls at btx_platform.
# VITE_BACKEND_ENDPOINT=http://127.0.0.1:8000
# VITE_COPILOT_ENDPOINT=http://127.0.0.1:8000/llm
# Artifact-mode cockpit builds fetch monitor output from this Pages path.
# VITE_ARTIFACT_BASE_URL=../btx

# Clerk (WP10-A): required to sign in. Publishable key only — safe for the
# browser bundle. Get it from your Clerk instance's API Keys page.
# VITE_CLERK_PUBLISHABLE_KEY=

# Legacy cosmetic gate (superseded by Clerk sign-in). Leave unset now that
# Clerk is the real access gate; kept only for local demo builds with no
# backend/auth configured at all.
# VITE_COCKPIT_PASSWORD_HASH=

# Model IDs — must be valid for your API key.
# VITE_MODEL_CHATPIL=claude-haiku-4-5-20251001   (default; used for Chatpil conversation)
# VITE_MODEL_COMPOSE=claude-sonnet-4-5            (default; used for deliverable composition)
