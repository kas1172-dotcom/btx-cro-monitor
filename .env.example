# BTX Engine — environment template. Copy to `.env` and fill in.
# NEVER commit real values. All platform settings use the BTX_ prefix.

# --- Integration platform (Engine #1) ---
BTX_ENV=dev
# Local default is SQLite; for Postgres use the compose service:
#   BTX_DATABASE_URL=postgresql+psycopg://btx:btx@localhost:5432/btx
BTX_DATABASE_URL=sqlite:///./btx_platform.db
BTX_REDIS_URL=redis://localhost:6379/0
BTX_MAX_ATTEMPTS=5
BTX_MAX_BODY_BYTES=1048576
BTX_FRONTEND_ORIGIN=http://localhost:5173
BTX_FRONTEND_ORIGINS=http://localhost:5173
BTX_BACKEND_AUTH_TOKEN=
BTX_ANTHROPIC_API_KEY=
BTX_HUBSPOT_ACCESS_TOKEN=
BTX_GMAIL_ALLOWLIST=
BTX_LLM_TIMEOUT_SECONDS=45
BTX_LLM_MAX_BODY_BYTES=524288
BTX_PIPELINE_MECHANISM=subprocess
BTX_PIPELINE_OUTPUT_DIR=clients/btx/artifacts
BTX_PIPELINE_GENERATED_DIR=.btx_platform/generated
BTX_PIPELINE_TIMEOUT_SECONDS=900
BTX_PIPELINE_MIN_INTERVAL_SECONDS=600
BTX_GITHUB_PAT=
BTX_GITHUB_REPO=kas1172-dotcom/btx-cro-monitor
BTX_GITHUB_WORKFLOW=monitor.yml
BTX_GITHUB_REF=main

# Per-connection webhook signing secrets live in the `connections` table
# (encrypt at rest in prod) — not here.

# --- Insights / newsletter engine (Engine #2, existing monitor_engine) ---
ANTHROPIC_API_KEY=
# Email delivery (Phase 6):
# RESEND_API_KEY=

# --- Static Enterprise Brain frontend demo ---
# demo = static snapshots, artifact = future static artifact, live = future API adapter
VITE_DATA_MODE=demo
VITE_BACKEND_ENDPOINT=http://localhost:8000
VITE_BACKEND_AUTH_TOKEN=
VITE_COPILOT_ENDPOINT=
